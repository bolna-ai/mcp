{
  "name": "bolna-mcp",
  "version": "0.1.0",
  "description": "Remote MCP server wrapping the Bolna Voice AI REST API.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "build:mcpb-server": "esbuild src/stdio.ts --bundle --platform=node --target=node18 --format=cjs --outfile=mcpb/server/index.js",
    "package:mcpb": "npm run build:mcpb-server && npx @anthropic-ai/mcpb pack mcpb bolna-mcp.mcpb"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "mcp-handler": "^1.1.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  }
}
